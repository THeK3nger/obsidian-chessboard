# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly text
*.ts    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.svg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary — never diff or convert
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
