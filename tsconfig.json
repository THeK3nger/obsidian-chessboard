{
  "compilerOptions": {
    "rootDir": "./src",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["dom", "es5", "scripthost", "es2015"],
  },
  "include": ["src/**/*.ts"],
}
